# (Recommended) Provide the direct connection string provided by Supabase Dashboard -> Settings -> Database -> Connection string (URI)
# DATABASE_URL=postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres

# --- SUPABASE CONFIG (STORAGE) ---
# Required for note uploads and PDF storage. Create a bucket named 'orion-x' in Supabase Storage.
SUPABASE_URL=https://[your-project-id].supabase.co
SUPABASE_KEY=[your-anon-role-key]

# --- GEMINI AI CONFIG ---
GEMINI_API_KEY=[your-google-gemini-api-key]

# --- AUTH CONFIG ---
SECRET_KEY=generate_a_random_hex_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE=1440
